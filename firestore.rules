rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isTeacher(teacherId) {
      return request.auth != null && request.auth.uid == teacherId;
    }

    function isValidSize() {
      return request.resource.data.keys().size() < 50;
    }

    function isValidString(field, maxLen) {
      return request.resource.data[field] is string
          && request.resource.data[field].size() <= maxLen;
    }

    match /teachers/{teacherId} {
      allow read: if true;
      allow write: if isTeacher(teacherId);

      match /classes/{classId} {
        allow read: if true;
        allow write: if isTeacher(teacherId);

        match /grass/{date} {
          allow read: if true;
          allow write: if isTeacher(teacherId);
        }

        match /teams/{teamId} {
          allow read: if true;
          allow write: if isTeacher(teacherId);
        }

        match /cookieShopItems/{itemId} {
          allow read: if true;
          allow write: if isTeacher(teacherId);
        }

        match /cookieShopRequests/{requestId} {
          allow read: if true;
          allow write: if isValidSize()
                       && request.resource.data.keys().hasAll(['itemId', 'studentCode', 'status'])
                       && request.resource.data.status in ['pending', 'approved', 'rejected'];
        }

        match /battles/{battleId} {
          allow read: if true;
          allow write: if isTeacher(teacherId);
        }

        match /wordclouds/{sessionId} {
          allow read: if true;
          allow write: if isTeacher(teacherId);

          match /responses/{studentCode} {
            allow read: if true;
            allow write: if isValidSize()
                         && request.resource.data.keys().size() <= 10;
          }
        }
      }

      match /students/{studentCode} {
        allow read: if true;
        allow write: if isValidSize();
      }

      match /shop/{itemId} {
        allow read: if true;
        allow write: if isTeacher(teacherId);
      }

      match /teams/{teamId} {
        allow read: if true;
        allow write: if isTeacher(teacherId);
      }

      match /wishes/{wishId} {
        allow read: if true;
        allow write: if isValidSize()
                     && request.resource.data.keys().size() <= 15;
      }

      match /cookieShopItems/{itemId} {
        allow read: if true;
        allow write: if isTeacher(teacherId);
      }

      match /cookieShopRequests/{requestId} {
        allow read: if true;
        allow write: if isValidSize()
                     && request.resource.data.keys().hasAll(['itemId', 'studentCode', 'status'])
                     && request.resource.data.status in ['pending', 'approved', 'rejected'];
      }

      match /itemSuggestions/{suggestionId} {
        allow read: if true;
        allow write: if isValidSize()
                     && request.resource.data.keys().size() <= 10;
      }

      match /classGroups/{groupId} {
        allow read: if true;
        allow write: if isTeacher(teacherId);
      }
    }

    match /games/{gameId} {
      allow read: if true;
      allow write: if isValidSize();

      match /players/{playerId} {
        allow read: if true;
        allow write: if isValidSize();
      }

      match /rounds/{roundId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      match /teams/{teamId} {
        allow read: if true;
        allow write: if isValidSize();
      }

      match /studentInfo/{studentCode} {
        allow read: if true;
        allow write: if isValidSize();
      }

      match /history/{docId} {
        allow read: if true;
        allow write: if isValidSize();
      }
    }

    match /shop/{itemId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /system/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /feedback/{feedbackId} {
      allow read: if true;
      allow create: if isValidSize()
                    && request.resource.data.keys().hasAll(['type', 'title', 'description'])
                    && request.resource.data.type in ['bug', 'feature'];
      allow update, delete: if false;
    }

    match /bp_system/{docId} {
      allow read: if true;
      allow write: if isValidSize();
    }

    match /bp_rooms/{roomCode} {
      allow read: if true;
      allow write: if isValidSize();
    }

    match /bp_sessions/{sessionId} {
      allow read: if true;
      allow write: if isValidSize();

      match /players/{playerId} {
        allow read: if true;
        allow write: if isValidSize();
      }

      match /matches/{matchId} {
        allow read: if true;
        allow write: if isValidSize();
      }
    }

    match /spectrum_battle/{roomCode} {
      allow read: if true;
      allow write: if isValidSize();

      match /players/{playerId} {
        allow read: if true;
        allow write: if isValidSize();
      }

      match /matches/{matchId} {
        allow read: if true;
        allow write: if isValidSize();
      }
    }
  }
}
